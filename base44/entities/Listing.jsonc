{
  "name": "Listing",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo do an\u00fancio"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada"
    },
    "category": {
      "type": "string",
      "enum": [
        "Alimentos da ro\u00e7a",
        "Latic\u00ednios",
        "Gado e animais",
        "Hortifruti",
        "M\u00e1quinas e ferramentas",
        "Artesanato rural",
        "Servi\u00e7os rurais",
        "Outros"
      ],
      "description": "Categoria"
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o em R$"
    },
    "city": {
      "type": "string",
      "description": "Cidade"
    },
    "region": {
      "type": "string",
      "description": "Regi\u00e3o / Estado (UF)"
    },
    "seller_name": {
      "type": "string",
      "description": "Nome do vendedor"
    },
    "seller_type": {
      "type": "string",
      "enum": [
        "Produtor",
        "Loja"
      ],
      "description": "Tipo de vendedor"
    },
    "whatsapp": {
      "type": "string",
      "description": "WhatsApp do vendedor"
    },
    "image_url": {
      "type": "string",
      "description": "URL da imagem principal"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Destaque"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "sold",
        "expired"
      ],
      "default": "active",
      "description": "Status"
    }
  },
  "required": [
    "title",
    "category",
    "price",
    "city",
    "seller_name",
    "whatsapp"
  ],
  "rls": {
    "create": {},
    "read": {},
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}